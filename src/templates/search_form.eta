<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Search</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
  <div class="container py-4" style="max-width: 760px">
    <a class="btn btn-sm btn-outline-secondary mb-3" href="/searches">&larr; All Searches</a>
    <h1 class="mb-4">New Search</h1>
    <form method="POST" action="/run_search">

      <h2 class="h5 mb-3">Conditions</h2>
      <div id="conditions">
        <div class="condition d-flex flex-column gap-2 mb-2 border rounded p-2">
          <div class="condition-fields d-flex flex-column gap-2">
            <div>
              <label class="form-label small text-muted mb-1">Regex (required)</label>
              <input type="text" class="form-control form-control-sm" name="regex[]" required placeholder="e.g. foo\w+" />
            </div>
            <div>
              <label class="form-label small text-muted mb-1">Not nearby (optional)</label>
              <input type="text" class="form-control form-control-sm" name="not_regex_nearby[]" placeholder="e.g. exclude" />
            </div>
          </div>
          <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-sm btn-outline-danger remove" onclick="removeCondition(this)" disabled>Remove condition</button>
          </div>
        </div>
      </div>
      <button type="button" class="btn btn-sm btn-outline-secondary mb-4" onclick="addCondition()">+ Add condition</button>

      <h2 class="h5 mb-3">Domains <small class="text-muted fw-normal fs-6">(leave all off to search all)</small></h2>
      <% if (it.domains && it.domains.length > 0) { %>
        <div id="domains" class="d-flex flex-wrap gap-2 mb-4">
          <% for (const d of it.domains) { %>
            <div>
              <input type="checkbox" class="btn-check domain-toggle" name="cdx_file_id[]" id="domain-<%= d.id %>" value="<%= d.id %>" autocomplete="off" />
              <label class="btn btn-sm btn-outline-secondary" for="domain-<%= d.id %>"><%= d.domain %></label>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-muted small mb-4">No domains found in database.</p>
      <% } %>

      <div>
        <button type="submit" class="btn btn-primary">Run Search</button>
      </div>
    </form>
  </div>

  <script>
    function updateRemoveButtons(container, selector) {
      const btns = container.querySelectorAll(selector);
      btns.forEach(btn => { btn.disabled = btns.length === 1; });
    }

    function addCondition() {
      const container = document.getElementById('conditions');
      const div = document.createElement('div');
      div.className = 'condition d-flex flex-column gap-2 mb-2 border rounded p-2';
      div.innerHTML = `
        <div class="condition-fields d-flex flex-column gap-2">
          <div>
            <label class="form-label small text-muted mb-1">Regex (required)</label>
            <input type="text" class="form-control form-control-sm" name="regex[]" required placeholder="e.g. foo\\w+" />
          </div>
          <div>
            <label class="form-label small text-muted mb-1">Not nearby (optional)</label>
            <input type="text" class="form-control form-control-sm" name="not_regex_nearby[]" placeholder="e.g. exclude" />
          </div>
        </div>
        <div class="d-flex justify-content-end">
          <button type="button" class="btn btn-sm btn-outline-danger remove" onclick="removeCondition(this)">Remove condition</button>
        </div>`;
      container.appendChild(div);
      updateRemoveButtons(container, 'button.remove');
    }

    function removeCondition(btn) {
      const container = document.getElementById('conditions');
      btn.closest('.condition').remove();
      updateRemoveButtons(container, 'button.remove');
    }

    document.querySelector('form').addEventListener('submit', function(e) {
      const toggles = document.querySelectorAll('.domain-toggle');
      if (toggles.length > 0 && ![...toggles].some(t => t.checked)) {
        e.preventDefault();
        alert('Please select at least one domain.');
        return;
      }
      const regexInputs = document.querySelectorAll('input[name="regex[]"]');
      for (const input of regexInputs) {
        const val = input.value.trim();
        if (!val) continue;
        try {
          new RegExp(val);
        } catch (err) {
          e.preventDefault();
          input.focus();
          alert('Invalid regex: ' + val + '\n' + err.message);
          return;
        }
      }
    });
  </script>
</body>
</html>
