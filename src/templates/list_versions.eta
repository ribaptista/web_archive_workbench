<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Versions — <%= it.url %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
  <div class="container py-4" style="max-width: 960px">
    <a class="btn btn-sm btn-outline-secondary mb-3" href="/resources">&larr; Resources</a>
    <h1 class="mb-1 fs-4">Versions</h1>
    <p class="text-muted mb-4 text-break"><%= it.url %></p>

    <ul class="list-group">
      <% for (const v of it.versions) { %>
        <li class="list-group-item d-flex align-items-center gap-2">
          <% if (v.status === 'ok' || v.status === 'redirect') { %>
            <a href="http://localhost:3000/replay/<%= v.timestamp %>/<%= it.url %>" target="_blank">
              <%= v.timestamp %>
            </a>
          <% } else { %>
            <span class="text-muted"><%= v.timestamp %></span>
          <% } %>

          <% if (v.status === 'ok') { %>
            <span class="badge bg-success">ok</span>
          <% } else if (v.status === 'redirect') { %>
            <span class="badge bg-info text-dark">redirect</span>
            <% if (v.location_original) { %>
              <span class="text-muted small">→
                <a href="http://localhost:3000/replay/<%= v.location_timestamp %>/<%= v.location_original %>" target="_blank" class="text-muted">
                  <%= v.location_original %>
                </a>
              </span>
            <% } %>
          <% } else if (v.status === 'error') { %>
            <span class="badge bg-danger">error</span>
            <% if (v.error_code) { %>
              <code class="small text-danger"><%= v.error_code %></code>
            <% } %>
            <% if (v.error_message) { %>
              <span class="text-muted small text-truncate" style="max-width:400px" title="<%= v.error_message %>"><%= v.error_message %></span>
            <% } %>
          <% } else { %>
            <span class="badge bg-secondary">pending</span>
          <% } %>
        </li>
      <% } %>
      <% if (it.versions.length === 0) { %>
        <li class="list-group-item text-muted">No versions found.</li>
      <% } %>
    </ul>
  </div>
</body>
</html>
